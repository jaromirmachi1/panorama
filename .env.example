# Server-only (Resend + Vercel). Do NOT use the VITE_ prefix.
# For local testing with `vercel dev`, copy to `.env.local` at the repo root.

RESEND_API_KEY=
# Must be an address on a domain verified in Resend, e.g. Panorama <poptavky@yourdomain.com>
RESEND_FROM_EMAIL=
# Where lead emails are delivered
INQUIRY_TO_EMAIL=

# Public site URL (no trailing slash). Canonical + OG tags in index.html; default: panoramazabiny.cz
# VITE_SITE_URL=https://panoramazabiny.cz

# Optional — Google Search Console → verify ownership → HTML tag → paste only the `content` value:
# VITE_GOOGLE_SITE_VERIFICATION=your_token_here

# Optional — only for `npm run dev` when the API runs elsewhere (e.g. preview URL):
# VITE_INQUIRY_API_BASE_URL=https://your-app.vercel.app
